    "phone.box.info" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie die Telefonnummern unserer Mitarbeiter:innen mit Ihrem Telefon synchronisieren möchten, so dass Sie benachrichtigt werden, wer Sie von unserer Firma anruft (wenn Sie die Person nicht in Ihren Kontakten haben), tippen Sie einfach auf die Schaltfläche „Synchronisieren“ und aktivieren Sie NEIN, um das Anrufverzeichnis zu verwenden!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you want to sync the phone numbers of our employees to your phone so you will get notified who is calling you from our company?(if you don't have the person in your contacts) just tap the sync button and enable NEIN to use the call directory!"
          }
        }
      }
    },
