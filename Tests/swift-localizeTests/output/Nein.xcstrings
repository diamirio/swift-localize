    "timetracking.status.description.locked" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Timesheet wurde gesperrt, da du es nicht rechtzeitig abgegeben hast. Wende dich – am besten mit einer Kiste Bier – an HR um es wieder freizuschalten zu lassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your timesheet has been blocked because you did not submit it on time. Contact HR - preferably with a crate of beer - to have it unlocked again."
          }
        }
      }
    },
